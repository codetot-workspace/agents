{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "9router": {
      "name": "9router (auto-fallback)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:20128/v1"
      },
      "models": {
        "kimi-k2-thinking": {
          "_launch": true,
          "name": "if/kimi-k2-thinking"
        },
        "qwen-code": {
          "name": "if/qwen-code"
        },
        "iflow-ai": {
          "name": "if/iflow-ai"
        }
      }
    },
    "ollama": {
      "name": "Ollama (local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        "qwen2.5-coder:14b": {
          "name": "qwen2.5-coder:14b"
        },
        "devstral": {
          "name": "devstral"
        }
      }
    }
  }
